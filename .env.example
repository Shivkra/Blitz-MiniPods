# SMTP Mail Configuration
# Set these variables in a local .env file to enable real email notifications to siva.k@blitznow.in

# Hostname of the SMTP server (e.g. smtp.gmail.com, smtp.resend.com, smtp.sendgrid.net)
SMTP_HOST=smtp.gmail.com

# Port of the SMTP server (commonly 587 for TLS or 465 for SSL)
SMTP_PORT=587

# Authentication Username (your email address)
SMTP_USER=your-email@gmail.com

# Authentication Password (or App Password for Gmail)
SMTP_PASS=your-app-password

# Set to true if using SSL (port 465) or false for TLS (port 587)
SMTP_SECURE=false

# Sender address shown in the "From" header (e.g. "Blitz Onboarding" <your-email@gmail.com>)
SMTP_FROM="Blitz Onboarding" <your-email@gmail.com>

# Target email to receive submissions (defaults to siva.k@blitznow.in if unset)
NOTIFICATION_EMAIL=siva.k@blitznow.in
